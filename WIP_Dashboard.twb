      <column caption='Agent Div Segmentation' datatype='string' name='[Calculation_2172986830936006656]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [avg_agent_diversity] &lt;= 2 THEN &quot;1-2 agents (One-trick)&quot;&#13;&#10;ELSEIF [avg_agent_diversity] &lt;= 5 THEN &quot;3-5 agents (Flexible)&quot;&#13;&#10;ELSEIF [avg_agent_diversity] &lt;= 9 THEN &quot;6-9 agents (Experimental)&quot;&#13;&#10;ELSE &quot;10+ agents (Explorer)&quot;&#13;&#10;END' />
      </column>
